# ── Portal Web ───────────────────────────────────────────────────────────────
# Host de escuta: 127.0.0.1 (só local, padrão dev) | 0.0.0.0 (acessível na rede, servidor)
# PORTAL_HOST=0.0.0.0
# PORTAL_PORT=8000
# PORTAL_RELOAD=false

# OpenRouter API Key (LLM fallback — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo usado no fallback (opcional — padrão: google/gemini-flash-1.5)
# Alternativas: anthropic/claude-haiku-4-5-20251001 | google/gemini-2.0-flash-lite
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Diretórios (padrão já configurado, altere se necessário)
INPUT_DIR=input/
OUTPUT_DIR=output/
LOG_DIR=logs/

# ── Firebird / Fire Sistemas ERP ─────────────────────────────────────────────
# Modo de exportação: xlsx (padrão) | db (somente banco) | both (ambos)
# EXPORT_MODE=xlsx

# Conexão embedded (arquivo local — copiar .fdb ou restaurar .fbk antes):
# FB_DATABASE=/caminho/para/empresa.fdb

# Se Firebird não está instalado no sistema, aponte para a dylib extraída:
# FB_CLIENT_LIBRARY=/tmp/fb_root/Versions/A/Resources/lib/libfbclient.dylib

# Conexão TCP (servidor Firebird remoto):
# FB_HOST=192.168.1.10
# FB_PORT=3050
# FB_DATABASE=C:\Fire\empresa.fdb
# FB_USER=SYSDBA
# FB_PASSWORD=masterkey

# Charset do banco (Fire Sistemas usa WIN1252 por padrão)
# FB_CHARSET=WIN1252

# Código da empresa em CAB_VENDAS.CODEMPRESA (padrão 1)
# FB_CODEMPRESA=1

# ── Gestor de Produção (integração outbound — Fase 3) ───────────────────────
# Wire format atual é PLACEHOLDER (ver app/integrations/gestor/schema.py).
# Substituir quando spec real chegar.
# GESTOR_BASE_URL=https://api.gestor-producao.example.com
# GESTOR_API_KEY=token-do-gestor

# Webhook inbound (Gestor → Portal). HMAC-SHA256 sobre f"{timestamp}.{body}".
# Suporta rotação: aceita CURRENT ou PREVIOUS por janela de transição.
# WEBHOOK_SECRET_GESTOR=secret-rotacionado-frequentemente
# WEBHOOK_SECRET_GESTOR_PREVIOUS=secret-anterior-aceito-temporariamente

# ── Hardening / Fase 6 ───────────────────────────────────────────────────────
# Rate-limit de login (token bucket SQLite). false = desliga (dev/test).
# RATE_LIMIT_ENABLED=true

# Worker: status no Firebird que dispara POST automático ao Gestor.
# Vazio = automação desligada (padrão seguro até confirmar com o cliente ERP).
# FIRE_TRIGGER_STATUS=

# Retenção: dias antes de purgar lifecycle_events e audit_log.
# RETENTION_DAYS=180

# Backup diário do SQLite via VACUUM INTO. Vazio = desativado.
# BACKUP_DIR=/var/backups/portal
