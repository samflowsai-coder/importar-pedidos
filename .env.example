# OpenRouter API Key (LLM fallback — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo usado no fallback (opcional — padrão: google/gemini-flash-1.5)
# Alternativas: anthropic/claude-haiku-4-5-20251001 | google/gemini-2.0-flash-lite
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Diretórios (padrão já configurado, altere se necessário)
INPUT_DIR=input/
OUTPUT_DIR=output/
LOG_DIR=logs/
